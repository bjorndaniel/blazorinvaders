@page "/leaderboard"
@inject HttpClient Http
@inject IConfiguration Config

<div class="row">
    <div class="col text-center">
        <h2>Leaderboard</h2>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-auto">
        @if (_scores == null)
        {
            <p>Loading...</p>
        }
        else if (_scores.Count == 0)
        {
            <p>No scores yet. Be the first!</p>
        }
        else
        {
            <table class="table table-dark table-striped" style="min-width:300px">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Score</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < _scores.Count; i++)
                    {
                        var rank = i + 1;
                        var entry = _scores[i];
                        <tr>
                            <td>@rank</td>
                            <td>@entry.Name</td>
                            <td>@entry.Score</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <a href="/" class="btn btn-secondary mt-2">Back to game</a>
    </div>
</div>

@code {
    private List<LeaderboardEntry>? _scores;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var url = $"{Config["FunctionsApi"]}/getleaderboard";
            _scores = await Http.GetFromJsonAsync<List<LeaderboardEntry>>(url) ?? new();
        }
        catch
        {
            _scores = new();
        }
    }

    private record LeaderboardEntry(string Name, int Score);
}
